{
  "name": "personal-os",
  "private": true,
  "packageManager": "npm@11.16.0",
  "workspaces": [
    "apps/web",
    "packages/shared-types",
    "packages/ui"
  ],
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "dev:web": "npm run dev --workspace=apps/web",
    "dev:api": "cd apps/api && uvicorn app.main:app --reload --port 8000",
    "db:migrate": "cd apps/api && alembic upgrade head",
    "db:revision": "cd apps/api && alembic revision --autogenerate -m",
    "db:reset": "cd apps/api && alembic downgrade base && alembic upgrade head"
  },
  "devDependencies": {
    "turbo": "^2.3.0"
  }
}
